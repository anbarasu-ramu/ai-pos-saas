{
  "info": {
    "_postman_id": "6c1e3cf8-5e2a-4d79-a58c-4f1df1e1c8af",
    "name": "AI POS SaaS Local",
    "description": "Local development collection for the AI POS SaaS stack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "keycloakBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "realm",
      "value": "ai-pos"
    },
    {
      "key": "bearerToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Backend",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            },
            "description": "Public backend health endpoint."
          }
        },
        {
          "name": "Auth Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "status"
              ]
            },
            "description": "Public auth metadata from the Spring Boot backend."
          }
        },
        {
          "name": "Register Tenant Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner+{{$timestamp}}@example.com\",\n  \"password\": \"Password1\",\n  \"tenantName\": \"Anbu Store\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Public registration endpoint that creates a tenant plus the first tenant administrator in Keycloak."
          }
        },
        {
          "name": "List Products",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Protected product scaffold endpoint. Paste a valid Keycloak access token into {{bearerToken}} first."
          }
        },
        {
          "name": "AI Chat",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Show low stock items\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/chat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ai",
                "chat"
              ]
            },
            "description": "Protected AI scaffold endpoint."
          }
        }
      ]
    },
    {
      "name": "Keycloak",
      "item": [
        {
          "name": "Realm OpenID Configuration",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{keycloakBaseUrl}}/realms/{{realm}}/.well-known/openid-configuration",
              "host": [
                "{{keycloakBaseUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                ".well-known",
                "openid-configuration"
              ]
            },
            "description": "Inspect the Keycloak OIDC endpoints for the imported ai-pos realm."
          }
        },
        {
          "name": "Realm Login Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{keycloakBaseUrl}}/realms/{{realm}}/account",
              "host": [
                "{{keycloakBaseUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "account"
              ]
            },
            "description": "Quick browser-style check that the realm is live."
          }
        }
      ]
    }
  ]
}
